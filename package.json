{
  "name": "anthonyjcastro-dot-com",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "homepage": "https://www.anthonyjcastro.com/",
  "scripts": {
    "build": "tsc -b && vite build",
    "build:e2e": "vite build --mode e2e",
    "clean": "rm -rf dist/*",
    "dev": "vite",
    "lint": "eslint .",
    "lint:ci": "npx eslint --quiet",
    "playwright": "npx playwright test --ui",
    "prettier": "prettier . --write",
    "prettier:ci": "prettier . --check",
    "preview": "vite preview",
    "preview:e2e": "vite preview --port 3000",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@analytics/google-analytics": "1.1.0",
    "analytics": "0.8.19",
    "clsx": "2.1.1",
    "modern-normalize": "3.0.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "use-analytics": "1.1.0"
  },
  "devDependencies": {
    "@anthony-j-castro/prettier-config": "github:anthony-j-castro/prettier-config#v1.1.2",
    "@babel/core": "7.29.7",
    "@babel/preset-env": "7.29.7",
    "@csstools/postcss-global-data": "4.0.0",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.60.0",
    "@rolldown/plugin-babel": "0.2.3",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/node": "25.9.2",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@types/use-analytics": "0.0.3",
    "@vitejs/plugin-react": "6.0.2",
    "babel-plugin-react-compiler": "1.0.0",
    "decoders": "2.9.3",
    "eslint": "10.4.1",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-package-json": "0.91.2",
    "eslint-plugin-perfectionist": "5.9.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-unicorn": "64.0.0",
    "globals": "17.6.0",
    "postcss-custom-media": "12.0.1",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vite": "8.0.16"
  }
}
